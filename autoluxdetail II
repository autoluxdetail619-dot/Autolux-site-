<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Auto Lux Detailing | Spring Valley CA</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: #0b0b0b;
      color: #f2f2f2;
      line-height: 1.6;
    }

    /* NAV */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 40px;
      background: #000;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    nav h1 {
      color: darkred;
      letter-spacing: 2px;
    }

    nav a {
      color: #ddd;
      margin-left: 20px;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover { color: darkred; }

    /* HERO */
    .hero {
      height: 90vh;
      background: linear-gradient(rgba(0,0,0,.7), rgba(0,0,0,.9)),
        url("https://images.unsplash.com/photo-1603386329225-868f9b1ee6c9") center/cover;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
    }

    .hero h2 {
      font-size: 3rem;
      color: darkred;
      margin-bottom: 15px;
    }

    .hero p {
      max-width: 600px;
      margin: auto;
      color: #ccc;
    }

    .btn {
      display: inline-block;
      margin: 25px 10px 0;
      padding: 14px 30px;
      background: darkred;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
    }

    /* SECTIONS */
    section {
      padding: 70px 25px;
      max-width: 1200px;
      margin: auto;
    }

    h3 {
      text-align: center;
      color: darkred;
      font-size: 2.2rem;
      margin-bottom: 40px;
    }

    /* SERVICES */
    .services {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
    }

    .card {
      background: #141414;
      border: 1px solid #2a2a2a;
      padding: 30px;
      border-radius: 12px;
      text-align: center;
    }

    .card h4 {
      color: darkred;
      margin-bottom: 10px;
      font-size: 1.4rem;
    }

    .price {
      font-size: 2rem;
      margin: 10px 0 20px;
    }

    /* GALLERY */
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
    }

    .gallery img {
      width: 100%;
      border-radius: 10px;
      object-fit: cover;
    }

    /* WHY US */
    .why {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 25px;
      text-align: center;
    }

    .why div {
      background: #141414;
      padding: 30px;
      border-radius: 12px;
      border: 1px solid #2a2a2a;
    }

    /* CONTACT */
    .contact {
      text-align: center;
    }

    footer {
      background: #000;
      text-align: center;
      padding: 40px 20px;
      color: #aaa;
    }

    @media (max-width: 600px) {
      .hero h2 { font-size: 2.2rem; }
      nav { flex-direction: column; }
    }
  </style>
</head>

<body>

<!-- NAV -->
<nav>
  <h1>Auto Lux</h1>
  <div>
    <a href="#services">Services</a>
    <a href="#gallery">Gallery</a>
    <a href="#contact">Contact</a>
    <a href="tel:6192544103">Book Now</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div>
    <h2>Premium Auto Detailing</h2>
    <p>Luxury-level interior & exterior detailing in Spring Valley, CA.</p>
    <a href="tel:6192544103" class="btn">Call / Text</a>
    <a href="#services" class="btn">View Services</a>
  </div>
</div>

<!-- SERVICES -->
<section id="services">
  <h3>Detailing Packages</h3>

  <div class="services">
    <div class="card">
      <h4>Basic Detail</h4>
      <div class="price">$20</div>
      <p>Quick maintenance wash & light interior clean.</p>
    </div>

    <div class="card">
      <h4>Standard Detail</h4>
      <div class="price">$40</div>
      <p>Deeper interior & exterior cleaning with shine.</p>
    </div>

    <div class="card">
      <h4>Premium Detail</h4>
      <div class="price">$90</div>
      <p>Full restoration-style detail for maximum results.</p>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section id="gallery">
  <h3>Before & After</h3>

  <div class="gallery">
    <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70">
    <img src="https://images.unsplash.com/photo-1603386329225-868f9b1ee6c9">
    <img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c">
    <img src="https://images.unsplash.com/photo-1553440569-bcc63803a83d">
  </div>
</section>

<!-- WHY US -->
<section>
  <h3>Why Choose Auto Lux</h3>

  <div class="why">
    <div>
      <h4>Detail Focused</h4>
      <p>Every vehicle is treated with precision and care.</p>
    </div>
    <div>
      <h4>Reliable Service</h4>
      <p>Consistent results, no shortcuts.</p>
    </div>
    <div>
      <h4>Local & Driven</h4>
      <p>Proudly serving Spring Valley, CA.</p>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="contact">
  <h3>Contact Us</h3>
  <p>📍 1111 Grand Ave, Spring Valley, CA</p>
  <p>📞 (619) 254-4103</p>
  <a href="tel:6192544103" class="btn">Book Now</a>
</section>

<footer>
  <p>© 2026 Auto Lux Detailing</p>
</footer>

</body>
</html>
